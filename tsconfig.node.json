{
  "extends": "@tsconfig/node22/tsconfig.json",
  "include": [
    "eslint.config.*",
    "tools/script/**/*.ts",
    "types/**/.*.d.ts",
    "types/**/*.d.ts"
  ],
  "compilerOptions": {
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "target": "ES2023",
    "baseUrl": "./",
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true
  }
}
